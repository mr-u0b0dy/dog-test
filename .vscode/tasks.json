{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake:configure-host",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "host-debug"],
      "group": "build"
    },
    {
      "label": "cmake:build-host",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "host-debug"],
      "group": "build"
    },
    {
      "label": "ctest:host",
      "type": "shell",
      "command": "ctest",
      "args": ["--preset", "host-debug"],
      "group": "test",
      "dependsOn": ["cmake:build-host"]
    }
  ]
}
